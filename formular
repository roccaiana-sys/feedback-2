<script>
const catConfig = {
  1: { required: ['q11','q12'] },
  2: { required: ['q21','q22'] },
  3: { required: ['q31','q32'] },
  4: { required: ['q41','q42','q43'] },
  5: { required: ['q51','q52','q54'] },
  6: { required: ['q61','q62'] }
};
const answers = {};

document.querySelectorAll('.scale-btn, .nps-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    const q = this.dataset.q;
    document.querySelectorAll(`[data-q="${q}"]`).forEach(b => b.classList.remove('active'));
    this.classList.add('active');
    answers[q] = this.dataset.val;
    updateProgress();
  });
});

document.querySelectorAll('.option-item input[type="radio"]').forEach(radio => {
  radio.addEventListener('change', function() {
    const name = this.name;
    document.querySelectorAll(`input[name="${name}"]`).forEach(r => r.closest('.option-item').classList.remove('selected'));
    this.closest('.option-item').classList.add('selected');
    answers[name] = this.value;
    updateProgress();
    if (name === 'q23') document.getElementById('q23-followup').classList.toggle('visible', this.value === 'Da');
    if (name === 'q33') document.getElementById('q33-followup').classList.toggle('visible', this.value === 'Da');
    if (name === 'q51') document.getElementById('q51-followup').classList.toggle('visible', this.value === 'Nu');
  });
});

// Star rating
document.querySelectorAll('.star-group input').forEach(radio => {
  radio.addEventListener('change', function() {
    answers[this.name] = this.value;
    updateProgress();
  });
});

function showQ(cat, q) {
  const body = document.querySelector(`#cat-${cat} .cat-body`);
  body.querySelectorAll('.question-wrap').forEach(w => w.classList.remove('visible'));
  const target = document.getElementById(`q-${cat}-${q}`);
  if (target) { target.classList.add('visible'); setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50); }
}

function nextQ(cat, currentQ) {
  const max = document.querySelectorAll(`#cat-${cat} .question-wrap`).length;
  if (currentQ < max) showQ(cat, currentQ + 1);
}

function prevQ(cat, currentQ) {
  if (currentQ > 1) showQ(cat, currentQ - 1);
}

function finishCat(cat) {
  const block = document.getElementById(`cat-${cat}`);
  block.classList.remove('active');
  const req = catConfig[cat].required;
  const done = req.filter(q => answers[q]).length;
  const statusEl = document.getElementById(`status-${cat}`);
  statusEl.textContent = done === req.length ? '✓ Completat' : `${done} / ${req.length}`;
  statusEl.classList.toggle('done', done === req.length);
  const nextCat = cat + 1;
  if (nextCat <= 6) {
    const next = document.getElementById(`cat-${nextCat}`);
    next.classList.add('active');
    setTimeout(() => next.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
  }
  updateProgress();
}

const allRequired = ['q11','q12','q21','q22','q31','q32','q41','q42','q43','q51','q52','q54','q61','q62'];

function updateProgress() {
  const done = allRequired.filter(q => answers[q]).length;
  document.getElementById('progressFill').style.width = (done / allRequired.length * 100) + '%';
}

function submitForm() {
  const missing = allRequired.filter(q => !answers[q]);
  if (missing.length > 0) {
    alert(`Mai sunt ${missing.length} câmpuri obligatorii necompletate. Vă rugăm reveniți asupra secțiunilor anterioare.`);
    return;
  }
  const data = {
    timestamp: new Date().toISOString(),
    ...answers,
    q23_detail: document.getElementById('q23-detail')?.value || '',
    q33_detail: document.getElementById('q33-detail')?.value || '',
    q51_contact: document.getElementById('q51-contact')?.value || '',
    q63: document.getElementById('q63')?.value || ''
  };
  const SHEETS_URL = 'https://script.google.com/macros/s/AKfycbwrwhYJSiHlPdrGQTiaJav2jDprli6xoDasz_Cifw4O5hnO_SiT9IyVuI__L23befo/exec';
  fetch(SHEETS_URL, { method: 'POST', mode: 'no-cors', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) }).catch(() => {});
  document.getElementById('formMain').style.display = 'none';
  document.getElementById('successScreen').style.display = 'block';
  document.getElementById('progressFill').style.width = '100%';
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>
